<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WhenWorks.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="940" d:DesignHeight="580"
        x:Class="WhenWorks.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="940"
        Height="580"
        WindowStartupLocation="CenterScreen"
        Title="WhenWorks"
        >

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Save..." Click="OnSave"/>
                <MenuItem Header="_Load..." Click="OnLoad"/>
            </MenuItem>
        </Menu>
        <Grid ColumnDefinitions="280,*" Margin="12" ColumnSpacing="12">

            <!-- Left side -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="People" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,8">
                    <TextBox Width="180" PlaceholderText="Name" Text="{Binding NewPersonName}"/>
                    <Button Content="Add" Command="{Binding AddPersonCommand}"/>
                </StackPanel>
                <Button DockPanel.Dock="Bottom" Content="Remove" Margin="0,8,0,0" Command="{Binding RemovePersonCommand}"/>
                <ListBox ItemsSource="{Binding People}" SelectedItem="{Binding SelectedPerson}"/>
            </DockPanel>

            <!-- Right side -->
            <DockPanel Grid.Column="1">

                <Border DockPanel.Dock="Top" BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Add availability for the selected person" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Start" Width="40" VerticalAlignment="Center"/>
                            <DatePicker SelectedDate="{Binding StartDate}"/>
                            <TimePicker SelectedTime="{Binding StartTime}" ClockIdentifier="12HourClock"/>
                            <!-- Use 24HourClock for 24-hour time format and 12HourClock for 12-hour time format -->
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="End" Width="40" VerticalAlignment="Center" />
                            <DatePicker SelectedDate="{Binding EndDate}"/>
                            <TimePicker SelectedTime="{Binding EndTime}" ClockIdentifier="12HourClock"/>
                        </StackPanel>
                        <Button Content="Add slot" HorizontalAlignment="Left" Command="{Binding AddSlotCommand}"/>
                    </StackPanel>
                </Border>

                <TextBlock DockPanel.Dock="Top" Text="Slots for selected person" FontWeight="Bold" Margin="0,0,0,8"/>
                <ListBox DockPanel.Dock="Top" Height="120" ItemsSource="{Binding SelectedPerson.Slots}" SelectedItem="{Binding SelectedSlot}"/>
                <Button DockPanel.Dock="Top" Content="Remove selected slot" Margin="0,8,0,0" HorizontalAlignment="Left" Command="{Binding RemoveSlotCommand}"/>

                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,8,0,8">
                    <Button Content="Find common times" Command="{Binding FindSlotsCommand}"/>
                    <TextBlock Text="At least" VerticalAlignment="Center"/>
                    <NumericUpDown Width="120" Minimum="1" Increment="1" Value="{Binding RequiredPeople}"/>
                    <TextBlock Text="people" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" Text="{Binding Status}" Foreground="Gray" Margin="0,24,0,0"/>

                <TextBlock DockPanel.Dock="Top" Text="Common availability" FontWeight="Bold" Margin="0,0,0,8"/>
                <ListBox ItemsSource="{Binding Res}"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
